# Server-side only — never prefix with NEXT_PUBLIC_.
# Both values come from your Spook site's Publishing settings (NextJS integration).
SPOOK_BLOG_API_URL=https://<your-deployment>.convex.site
SPOOK_BLOG_API_KEY=spook_blog_xxxxxxxx

# Your production origin — used by the blog sitemap and RSS feed.
NEXT_PUBLIC_SITE_URL=https://yoursite.com
